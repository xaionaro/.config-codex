#!/usr/bin/env bash
# Manage the stop-hook bypass marker for the current Codex session.

set -euo pipefail

root="${CODEX_PROOF_ROOT:-$HOME/.cache/codex-proof}"

usage() {
  cat >&2 <<'EOF'
Usage:
  skip-stop on
  skip-stop off
  skip-stop status

Set CODEX_SESSION_ID to target a specific session. Without it, the newest
session directory under ~/.cache/codex-proof is used.
EOF
}

session_dir() {
  if [ -n "${CODEX_SESSION_ID:-}" ]; then
    case "$CODEX_SESSION_ID" in
      *[!A-Za-z0-9_-]*) return 1 ;;
    esac
    printf '%s/%s\n' "$root" "$CODEX_SESSION_ID"
    return 0
  fi

  find "$root" -mindepth 1 -maxdepth 1 -type d -printf '%T@ %p\n' 2>/dev/null |
    sort -rn |
    awk 'NR == 1 {print $2}'
}

cmd="${1:-}"
case "$cmd" in
  on)
    dir=$(session_dir)
    [ -n "$dir" ] || { echo "No Codex proof session found; set CODEX_SESSION_ID." >&2; exit 1; }
    mkdir -p "$dir"
    date -u '+created_utc: %Y-%m-%dT%H:%M:%SZ' >"$dir/skip_stop"
    printf 'Stop hook bypass enabled: %s/skip_stop\n' "$dir"
    ;;
  off)
    dir=$(session_dir)
    [ -n "$dir" ] || { echo "No Codex proof session found; set CODEX_SESSION_ID." >&2; exit 1; }
    rm -f "$dir/skip_stop"
    printf 'Stop hook bypass disabled\n'
    ;;
  status)
    dir=$(session_dir || true)
    if [ -n "${dir:-}" ] && [ -f "$dir/skip_stop" ]; then
      cat "$dir/skip_stop"
    else
      echo "Stop hook bypass inactive"
    fi
    ;;
  *)
    usage
    exit 2
    ;;
esac
