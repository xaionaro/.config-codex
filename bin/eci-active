#!/usr/bin/env bash
# Manage the ECI active marker for the current Codex session or cwd.

set -euo pipefail

base_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
. "$base_dir/hooks/lib/codex-proof-state.sh"

usage() {
  cat >&2 <<'EOF'
Usage:
  eci-active on "<task + scope>"
  eci-active off <disengage-report.md>
  eci-active status

Set CODEX_SESSION_ID to target a specific session. Without it, the newest
proof directory is never guessed; state is scoped to the current cwd.
EOF
}

section_has_body() {
  local file="$1"
  local target="$2"

  awk -v target="$target" '
    BEGIN { target = tolower(target) }
    function trim(s) {
      gsub(/^[[:space:]]+|[[:space:]]+$/, "", s)
      return s
    }
    /^##[[:space:]]*/ {
      heading = $0
      sub(/^##[[:space:]]*/, "", heading)
      heading = tolower(trim(heading))
      if (in_section) exit
      if (heading == target) {
        in_section = 1
        next
      }
    }
    in_section {
      line = trim($0)
      if (line != "") found = 1
    }
    END { exit(found ? 0 : 1) }
  ' "$file"
}

terminal_verdict_count() {
  awk '
    {
      line = tolower($0)
      while (match(line, /(^|[^[:alnum:]_-])(clean-pass|hard-escalation|user-closed):/)) {
        count++
        line = substr(line, RSTART + RLENGTH)
      }
    }
    END { print count + 0 }
  ' "$1"
}

validate_disengage_report() {
  local report="$1"
  local missing=""
  local section

  for section in "Stop checklist walkthrough" "Incomplete compliance"; do
    if ! section_has_body "$report" "$section"; then
      missing="$missing \"$section\""
    fi
  done

  if [ -n "$missing" ]; then
    echo "Disengage report missing non-empty ECI section(s):$missing" >&2
    return 1
  fi

  local verdicts
  verdicts=$(terminal_verdict_count "$report")
  if [ "$verdicts" -ne 1 ]; then
    echo "Disengage report must include exactly one terminal verdict marker: clean-pass:, hard-escalation:, or user-closed:." >&2
    return 1
  fi

  if section_has_body "$report" "ECI completion certificate"; then
    return 0
  fi

  local proof_missing=""
  for section in \
    "Summary" \
    "Verification" \
    "Requirements" \
    "Root Cause" \
    "Claim Inventory" \
    "Pre-Mortem" \
    "Adversarial Critique" \
    "Rule-Compliance Self-Audit" \
    "Gaps"; do
    if ! section_has_body "$report" "$section"; then
      proof_missing="$proof_missing \"$section\""
    fi
  done

  if [ -n "$proof_missing" ]; then
    echo "Disengage report must include either a non-empty \"ECI completion certificate\" section or all full Codex stop-proof sections." >&2
    echo "Missing full stop-proof section(s):$proof_missing" >&2
    return 1
  fi
}

cmd="${1:-}"
case "$cmd" in
  on)
    shift
    scope="${*:-}"
    [ -n "$scope" ] || { usage; exit 2; }
    marker=$(codex_cli_state_file eci eci_active true) || {
      echo "Invalid CODEX_SESSION_ID; use only letters, digits, '_' or '-'." >&2
      exit 1
    }
    {
      printf 'scope: %s\n' "$scope"
      printf 'cwd: %s\n' "$PWD"
      if [ -n "${CODEX_SESSION_ID:-}" ]; then
        printf 'session_id: %s\n' "$CODEX_SESSION_ID"
      fi
      date -u '+created_utc: %Y-%m-%dT%H:%M:%SZ'
    } >"$marker"
    printf 'ECI active: %s\n' "$marker"
    ;;
  off)
    report="${2:-}"
    [ -n "$report" ] || { usage; exit 2; }
    [ -f "$report" ] || { echo "Disengage report not found: $report" >&2; exit 1; }
    marker=$(codex_cli_state_file eci eci_active false) || {
      echo "Invalid CODEX_SESSION_ID; use only letters, digits, '_' or '-'." >&2
      exit 1
    }
    [ -f "$marker" ] || { echo "ECI marker is not active: $marker" >&2; exit 1; }
    validate_disengage_report "$report"
    proof_session="${CODEX_SESSION_ID:-}"
    if ! codex_valid_session_id "$proof_session"; then
      proof_session="$(codex_state_session_id "$marker" || true)"
    fi
    if ! codex_valid_session_id "$proof_session"; then
      echo "ECI marker is active but is not associated with a Codex session." >&2
      echo "Run the stop/ECI gate once in the target session before disengaging, or activate ECI with CODEX_SESSION_ID set." >&2
      exit 1
    fi
    cp "$report" "$(dirname "$marker")/proof.md"
    proof_dir="$(codex_proof_root)/$proof_session"
    mkdir -p "$proof_dir"
    cp "$report" "$proof_dir/proof.md"
    rm -f "$marker"
    printf 'ECI inactive. Proof copied to %s/proof.md\n' "$(dirname "$marker")"
    ;;
  status)
    marker=$(codex_cli_state_file eci eci_active false 2>/dev/null || true)
    if [ -n "${marker:-}" ] && [ -f "$marker" ]; then
      cat "$marker"
    else
      echo "ECI inactive"
    fi
    ;;
  *)
    usage
    exit 2
    ;;
esac
