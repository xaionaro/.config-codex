#!/usr/bin/env bash
# Manage the ECI active marker for the current Codex session.

set -euo pipefail

root="${CODEX_PROOF_ROOT:-$HOME/.cache/codex-proof}"

usage() {
  cat >&2 <<'EOF'
Usage:
  eci-active on "<task + scope>"
  eci-active off <disengage-report.md>
  eci-active status

Set CODEX_SESSION_ID to target a specific session. Without it, the newest
session directory under ~/.cache/codex-proof is used.
EOF
}

session_dir() {
  if [ -n "${CODEX_SESSION_ID:-}" ]; then
    case "$CODEX_SESSION_ID" in
      *[!A-Za-z0-9_-]*) return 1 ;;
    esac
    printf '%s/%s\n' "$root" "$CODEX_SESSION_ID"
    return 0
  fi

  find "$root" -mindepth 1 -maxdepth 1 -type d -printf '%T@ %p\n' 2>/dev/null |
    sort -rn |
    awk 'NR == 1 {print $2}'
}

section_has_body() {
  local file="$1"
  local target="$2"

  awk -v target="$target" '
    BEGIN { target = tolower(target) }
    function trim(s) {
      gsub(/^[[:space:]]+|[[:space:]]+$/, "", s)
      return s
    }
    /^##[[:space:]]*/ {
      heading = $0
      sub(/^##[[:space:]]*/, "", heading)
      heading = tolower(trim(heading))
      if (in_section) exit
      if (heading == target) {
        in_section = 1
        next
      }
    }
    in_section {
      line = trim($0)
      if (line != "") found = 1
    }
    END { exit(found ? 0 : 1) }
  ' "$file"
}

terminal_verdict_count() {
  awk '
    {
      line = tolower($0)
      while (match(line, /(^|[^[:alnum:]_-])(clean-pass|hard-escalation|user-closed):/)) {
        count++
        line = substr(line, RSTART + RLENGTH)
      }
    }
    END { print count + 0 }
  ' "$1"
}

validate_disengage_report() {
  local report="$1"
  local missing=""
  local section

  for section in "Stop checklist walkthrough" "Incomplete compliance"; do
    if ! section_has_body "$report" "$section"; then
      missing="$missing \"$section\""
    fi
  done

  if [ -n "$missing" ]; then
    echo "Disengage report missing non-empty ECI section(s):$missing" >&2
    return 1
  fi

  local verdicts
  verdicts=$(terminal_verdict_count "$report")
  if [ "$verdicts" -ne 1 ]; then
    echo "Disengage report must include exactly one terminal verdict marker: clean-pass:, hard-escalation:, or user-closed:." >&2
    return 1
  fi

  if section_has_body "$report" "ECI completion certificate"; then
    return 0
  fi

  local proof_missing=""
  for section in \
    "Summary" \
    "Verification" \
    "Requirements" \
    "Root Cause" \
    "Claim Inventory" \
    "Pre-Mortem" \
    "Adversarial Critique" \
    "Rule-Compliance Self-Audit" \
    "Gaps"; do
    if ! section_has_body "$report" "$section"; then
      proof_missing="$proof_missing \"$section\""
    fi
  done

  if [ -n "$proof_missing" ]; then
    echo "Disengage report must include either a non-empty \"ECI completion certificate\" section or all full Codex stop-proof sections." >&2
    echo "Missing full stop-proof section(s):$proof_missing" >&2
    return 1
  fi
}

cmd="${1:-}"
case "$cmd" in
  on)
    shift
    scope="${*:-}"
    [ -n "$scope" ] || { usage; exit 2; }
    dir=$(session_dir)
    [ -n "$dir" ] || { echo "No Codex proof session found; set CODEX_SESSION_ID." >&2; exit 1; }
    mkdir -p "$dir"
    {
      printf 'scope: %s\n' "$scope"
      printf 'cwd: %s\n' "$PWD"
      date -u '+created_utc: %Y-%m-%dT%H:%M:%SZ'
    } >"$dir/eci_active"
    printf 'ECI active: %s\n' "$dir/eci_active"
    ;;
  off)
    report="${2:-}"
    [ -n "$report" ] || { usage; exit 2; }
    [ -f "$report" ] || { echo "Disengage report not found: $report" >&2; exit 1; }
    dir=$(session_dir)
    [ -n "$dir" ] || { echo "No Codex proof session found; set CODEX_SESSION_ID." >&2; exit 1; }
    mkdir -p "$dir"
    [ -f "$dir/eci_active" ] || { echo "ECI marker is not active for session: $dir" >&2; exit 1; }
    validate_disengage_report "$report"
    cp "$report" "$dir/proof.md"
    rm -f "$dir/eci_active"
    printf 'ECI inactive. Proof copied to %s/proof.md\n' "$dir"
    ;;
  status)
    dir=$(session_dir || true)
    if [ -n "${dir:-}" ] && [ -f "$dir/eci_active" ]; then
      cat "$dir/eci_active"
    else
      echo "ECI inactive"
    fi
    ;;
  *)
    usage
    exit 2
    ;;
esac
