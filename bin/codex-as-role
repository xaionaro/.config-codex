#!/usr/bin/env bash
# Launch Codex with CODEX_ROLE set for role-aware hooks.

set -euo pipefail

role="${1:-}"
if [ -z "$role" ]; then
  cat >&2 <<'EOF'
Usage: codex-as-role <role> [codex args...]

Allowed roles:
  coordinator lead explorer designer reviewer executor
  test-designer test-executor test-reviewer verifier qa
  brainstormer snitch eci-implementer
EOF
  exit 2
fi
shift

case "$role" in
  coordinator|lead|explorer|designer|reviewer|executor|test-designer|test-executor|test-reviewer|verifier|qa|brainstormer|snitch|eci-implementer) ;;
  *)
    echo "Unsupported CODEX_ROLE: $role" >&2
    exit 2
    ;;
esac

export CODEX_ROLE="$role"
exec codex "$@"
