{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume|clear",
        "hooks": [
          {
            "type": "command",
            "command": "bash -lc 'exec \"${CODEX_HOME:-$HOME/.codex}/hooks/session-snapshot.sh\"'",
            "statusMessage": "Loading Codex session rules"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash -lc 'exec \"${CODEX_HOME:-$HOME/.codex}/hooks/prompt-task-reminder.sh\"'"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "^Bash$",
        "hooks": [
          {
            "type": "command",
            "command": "bash -lc 'exec \"${CODEX_HOME:-$HOME/.codex}/hooks/validate-bash.sh\"'",
            "statusMessage": "Checking shell command"
          },
          {
            "type": "command",
            "command": "bash -lc 'exec \"${CODEX_HOME:-$HOME/.codex}/hooks/edit-bash-pre-reviewer.sh\"'",
            "statusMessage": "Checking first tool call"
          }
        ]
      },
      {
        "matcher": "^apply_patch$",
        "hooks": [
          {
            "type": "command",
            "command": "bash -lc 'exec \"${CODEX_HOME:-$HOME/.codex}/hooks/validate-apply-patch.sh\"'",
            "statusMessage": "Checking file edit"
          },
          {
            "type": "command",
            "command": "bash -lc 'exec \"${CODEX_HOME:-$HOME/.codex}/hooks/security-reminder.py\"'",
            "statusMessage": "Checking security-sensitive edit"
          },
          {
            "type": "command",
            "command": "bash -lc 'exec \"${CODEX_HOME:-$HOME/.codex}/hooks/eci-active-gate.sh\"'",
            "statusMessage": "Checking ECI gate"
          },
          {
            "type": "command",
            "command": "bash -lc 'exec \"${CODEX_HOME:-$HOME/.codex}/hooks/ate-orchestrator-gate.sh\"'",
            "statusMessage": "Checking role gate"
          },
          {
            "type": "command",
            "command": "bash -lc 'exec \"${CODEX_HOME:-$HOME/.codex}/hooks/edit-bash-pre-reviewer.sh\"'",
            "statusMessage": "Checking first tool call"
          }
        ]
      },
      {
        "matcher": "^(Edit|Write|MultiEdit|NotebookEdit)$",
        "hooks": [
          {
            "type": "command",
            "command": "bash -lc 'exec \"${CODEX_HOME:-$HOME/.codex}/hooks/validate-edit-write.sh\"'",
            "statusMessage": "Checking file edit"
          },
          {
            "type": "command",
            "command": "bash -lc 'exec \"${CODEX_HOME:-$HOME/.codex}/hooks/security-reminder.py\"'",
            "statusMessage": "Checking security-sensitive edit"
          },
          {
            "type": "command",
            "command": "bash -lc 'exec \"${CODEX_HOME:-$HOME/.codex}/hooks/eci-active-gate.sh\"'",
            "statusMessage": "Checking ECI gate"
          },
          {
            "type": "command",
            "command": "bash -lc 'exec \"${CODEX_HOME:-$HOME/.codex}/hooks/ate-orchestrator-gate.sh\"'",
            "statusMessage": "Checking role gate"
          },
          {
            "type": "command",
            "command": "bash -lc 'exec \"${CODEX_HOME:-$HOME/.codex}/hooks/edit-bash-pre-reviewer.sh\"'",
            "statusMessage": "Checking first tool call"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash -lc 'exec \"${CODEX_HOME:-$HOME/.codex}/hooks/stop-gate.sh\"'",
            "timeout": 300,
            "statusMessage": "Checking stop criteria"
          }
        ]
      }
    ]
  }
}
